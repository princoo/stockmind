# PostgreSQL connection URL for Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/database_name?schema=public"

# NextAuth configuration.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_long_random_secret"

# SMTP configuration for supplier email notifications.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp_user"
SMTP_PASS="smtp_password"
SMTP_FROM="SmartStock <noreply@smartstock.local>"

# Anthropic (StockPilot chat model).
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Deepgram (speech-to-text for voice input).
DEEPGRAM_API_KEY="your_deepgram_api_key"

# ElevenLabs (text-to-speech for voice conversation mode).
ELEVENLABS_API_KEY="your_elevenlabs_api_key"
# Optional: override default voice (Sarah) and model.
# ELEVENLABS_VOICE_ID="EXAVITQu4vr4xnSDxMaL"
# ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"
